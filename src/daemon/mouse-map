#!/bin/bash

CONFIG_FILE="$HOME/.config/mouse-switcher/profiles.json"

echo "🖱️  Mouse Profile Switcher - Map New Game"
echo "----------------------------------------"
echo "When you press Enter, you will have 3 seconds to click on your game window."
read -p "Press Enter when ready..."

for i in {3..1}; do
    echo -ne "Capturing in $i...\r"
    sleep 1
done
echo "Capturing now!      "

WINDOW_CLASS=$(kdotool getactivewindow getwindowclassname 2>/dev/null)
WINDOW_NAME=$(kdotool getactivewindow getwindowname 2>/dev/null)

if [ -z "$WINDOW_CLASS" ]; then
    echo "❌ Error: Could not detect an active window."
    exit 1
fi

echo ""
echo "✅ Window Detected!"
echo "   Name:  $WINDOW_NAME"
echo "   Class: $WINDOW_CLASS"
echo ""

read -p "Enter the exact Input Remapper preset name for this game: " PRESET_NAME

if [ -z "$PRESET_NAME" ]; then
    echo "❌ Error: Preset name cannot be empty. Aborting."
    exit 1
fi

if [ ! -f "$CONFIG_FILE" ]; then
    echo "❌ Error: $CONFIG_FILE not found. Please run the GUI once to generate it."
    exit 1
fi

# Use inline python to safely append the window class to the array format
python3 -c "
import json, sys
config_file = sys.argv[1]
win_class = sys.argv[2]
preset = sys.argv[3]

with open(config_file, 'r') as f:
    data = json.load(f)

# Modify the first available sync group
groups = list(data.get('sync_groups', {}).keys())
if not groups:
    sys.exit(1)

active_group = groups[0]
mappings = data['sync_groups'][active_group].setdefault('mappings', {})

# Remove the window class if it exists in another preset array
for p_name, windows in mappings.items():
    if win_class in windows:
        windows.remove(win_class)

# Add to the new preset
if preset not in mappings:
    mappings[preset] = []
    
if win_class not in mappings[preset]:
    mappings[preset].append(win_class)

# Clean up empty arrays to keep JSON tidy
data['sync_groups'][active_group]['mappings'] = {k: v for k, v in mappings.items() if v}

with open(config_file, 'w') as f:
    json.dump(data, f, indent=4)
" "$CONFIG_FILE" "$WINDOW_CLASS" "$PRESET_NAME"

if [ $? -eq 0 ]; then
    echo "✅ Added mapping: $WINDOW_CLASS -> $PRESET_NAME"
    echo "🎉 Done! Your mouse will now switch instantly."
else
    echo "❌ Error modifying $CONFIG_FILE"
fi