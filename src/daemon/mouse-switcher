#!/bin/bash

exec > "$HOME/.mouse-switcher.log" 2>&1
echo "=== Mouse Switcher Started at $(date) ==="
echo "Detected Session: $XDG_SESSION_TYPE / $XDG_CURRENT_DESKTOP"

CONFIG_FILE="$HOME/.config/mouse-switcher/profiles.json"
PRESET_DIR="$HOME/.config/input-remapper-2/presets"
sleep 3
last_preset="Booting"

declare -A DEVICE_MAP
TARGET_PRESET=""

# --- 1. ENVIRONMENT-AWARE WINDOW DETECTION ---
get_active_window_class() {
    if [ "$XDG_CURRENT_DESKTOP" == "KDE" ] && [ "$XDG_SESSION_TYPE" == "wayland" ] && command -v kdotool >/dev/null; then
        kdotool getactivewindow getwindowclassname 2>/dev/null
    
    elif [ "$XDG_CURRENT_DESKTOP" == "Hyprland" ] && command -v hyprctl >/dev/null; then
        hyprctl activewindow -j 2>/dev/null | awk -F'"' '/"class":/ {print $4}'
        
    elif command -v xdotool >/dev/null; then
        xdotool getactivewindow getwindowclassname 2>/dev/null
    fi
}

# --- 2. CONFIG & SYNC LOGIC ---
get_config() {
    local target_window="$1"
    TARGET_PRESET=""
    DEVICE_MAP=()
    
    if [ ! -f "$CONFIG_FILE" ]; then
        return
    fi

    # 1. Safely find the Sync Group that maps this window
    local active_group
    active_group=$(jq -r --arg win "$target_window" '
        .sync_groups | to_entries[]? | 
        select(.value.mappings | to_entries[]? | select(.value | type == "array" and index($win))) | 
        .key
    ' "$CONFIG_FILE" | head -n 1)

    # 2. Fallback to the first Sync Group if the window is unmapped
    if [ -z "$active_group" ] || [ "$active_group" == "null" ]; then
        active_group=$(jq -r '.sync_groups | keys_unsorted[0]' "$CONFIG_FILE")
    fi

    if [ -z "$active_group" ] || [ "$active_group" == "null" ]; then
        return
    fi

    # 3. Extract devices
    while IFS="=" read -r dev hash; do
        [[ -n "$dev" ]] && DEVICE_MAP["$dev"]="$hash"
    done < <(jq -r --arg grp "$active_group" '.sync_groups[$grp].devices | to_entries[]? | "\(.value.dev_name)=\(.value.hash)"' "$CONFIG_FILE")
    # 4. Resolve the Target Preset
    TARGET_PRESET=$(jq -r --arg win "$target_window" --arg grp "$active_group" '
        .sync_groups[$grp].mappings | to_entries[]? | 
        select(.value | type == "array" and index($win)) | 
        .key
    ' "$CONFIG_FILE" | head -n 1)

    # 5. Fallback to default mapping
    if [ -z "$TARGET_PRESET" ] || [ "$TARGET_PRESET" == "null" ]; then
        TARGET_PRESET=$(jq -r --arg grp "$active_group" '
            .sync_groups[$grp].mappings | to_entries[]? | 
            select(.value | type == "array" and index("default")) | 
            .key
        ' "$CONFIG_FILE" | head -n 1)
    fi

    TARGET_PRESET="${TARGET_PRESET:-Default}"
}

sync_preset() {
    local preset="$1"
    local newest_file=""
    local newest_dev=""
    local newest_hash=""
    local newest_time=0

    for dev in "${!DEVICE_MAP[@]}"; do
        local check_file="$PRESET_DIR/$dev/$preset.json"
        if [ -f "$check_file" ]; then
            local mtime=$(stat -c %Y "$check_file")
            if [ "$mtime" -gt "$newest_time" ]; then
                newest_time=$mtime
                newest_file=$check_file
                newest_dev=$dev
                newest_hash=${DEVICE_MAP[$dev]}
            fi
        fi
    done

    if [ -n "$newest_file" ]; then
        for target_dev in "${!DEVICE_MAP[@]}"; do
            if [ "$target_dev" != "$newest_dev" ]; then
                local target_file="$PRESET_DIR/$target_dev/$preset.json"
                local target_hash="${DEVICE_MAP[$target_dev]}"
                
                mkdir -p "$PRESET_DIR/$target_dev"
                
                if [ ! -f "$target_file" ] || [ "$newest_file" -nt "$target_file" ]; then
                    cp "$newest_file" "$target_file"
                    sed -i "s/$newest_hash/$target_hash/g" "$target_file"
                    echo "Synced $preset: $newest_dev -> $target_dev"
                fi
            fi
        done
    fi
}

inject_hash_into_preset() {
    local preset_path="$1"
    local new_hash="$2"

    # Use jq to update the nested origin_hash in all elements of the JSON array
    if [[ -f "$preset_path" ]]; then
        jq --arg hash "$new_hash" \
           'map(.input_combination[].origin_hash = $hash)' \
           "$preset_path" > "${preset_path}.tmp" && mv "${preset_path}.tmp" "$preset_path"
    fi
}

apply_profile() {
    local preset="$1"
    
    # 1. Get current physical hardware IDs from lsusb
    # This outputs lines like: Bus 003 Device 004: ID 1532:00a7 Razer USA, Ltd
    local connected_usb_ids
    connected_usb_ids=$(lsusb | awk -F 'ID ' '{print $2}' | cut -d' ' -f1 | tr '[:upper:]' '[:lower:]')

    # 2. Get the active group
    local active_group
    active_group=$(jq -r '.sync_groups | keys[0]' "$CONFIG_FILE")

    # 3. Iterate over devices defined in this group
    mapfile -t devices < <(jq -r --arg grp "$active_group" \
        '.sync_groups[$grp].devices | to_entries[] | "\(.key)|\(.value.dev_name)|\(.value.hash)"' \
        "$CONFIG_FILE")

    for entry in "${devices[@]}"; do
        IFS="|" read -r vid_pid dev_name dev_hash <<< "$entry"
        
        # 4. Filter by physical VID:PID match
        if echo "$connected_usb_ids" | grep -q "$vid_pid"; then
            local preset_path="$HOME/.config/input-remapper-2/presets/$dev_name/$preset.json"

            if [[ -f "$preset_path" ]]; then
                # Inject the hash (using the function from before)
                inject_hash_into_preset "$preset_path" "$dev_hash"

                # Apply the profile
                input-remapper-control --command start --device "$dev_name" --preset "$preset" > /dev/null 2>&1
            fi
        else
            echo "[DEBUG] Device $dev_name (VID:PID $vid_pid) not found via lsusb. Skipping."
        fi
    done
    
    last_preset="$preset"
}

trigger_check() {
    # Check if manual override is active
    if grep -q "(Manual)" "$HOME/.config/mouse-switcher/active.state" 2>/dev/null; then
        last_preset="MANUAL_OVERRIDE"
        return
    fi

    local window_name
    local preset

    window_name=$(get_active_window_class | tr -d '\n')

    if [ -f "$CONFIG_FILE" ]; then
        get_config "$window_name"
        preset="$TARGET_PRESET"
    else
        preset="Default"
    fi

    preset="${preset:-Default}"

    # Only fire the switch if the profile actually changed
    if [ "$last_preset" != "$preset" ]; then
        echo "$preset" > "$HOME/.config/mouse-switcher/active.state"
        echo "Profile update event ($preset): $window_name"
        apply_profile "$preset"
    fi
}

# --- 3. ENVIRONMENT-AWARE EVENT LISTENER ---
watch_window_events() {
    if [ "$XDG_CURRENT_DESKTOP" == "KDE" ] && [ "$XDG_SESSION_TYPE" == "wayland" ]; then
        echo "Using KDE Wayland D-Bus watcher..."
        dbus-monitor --session "type='signal',member='RunningApplicationsChanged'" | \
        while read -r line; do
            sleep 0.2
            trigger_check
        done

    elif [ "$XDG_CURRENT_DESKTOP" == "Hyprland" ] && command -v socat >/dev/null; then
        echo "Using Hyprland socket watcher..."
        socat -U - UNIX-CONNECT:"$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" | \
        while read -r line; do
            if [[ "$line" == activewindow* ]]; then
                trigger_check
            fi
        done

    elif [ "$XDG_SESSION_TYPE" == "x11" ] || command -v xprop >/dev/null; then
        echo "Using X11 xprop watcher..."
        xprop -root -spy _NET_ACTIVE_WINDOW | \
        while read -r line; do
            trigger_check
        done

    else
        echo "No native event watcher found. Falling back to 1-second polling loop..."
        while true; do
            trigger_check
            sleep 1
        done
    fi
}

trigger_check
watch_window_events